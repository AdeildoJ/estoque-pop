# Copie para .env.local (desenvolvimento) ou adicione na Vercel → Settings → Environment Variables

KV_REST_API_URL=https://xxxx.upstash.io
KV_REST_API_TOKEN=seu_token_de_escrita

# A Vercel também pode criar estes nomes ao conectar Upstash:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Use o token de ESCRITA — não use KV_REST_API_READ_ONLY_TOKEN para o app

# Opcional: proteger webhook do n8n
# API_KEY=
